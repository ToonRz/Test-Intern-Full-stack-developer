# Application
APP_NAME="Log Management System"
DEBUG=false
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/logs

# JWT Authentication
SECRET_KEY=change-me-in-production-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Syslog Listener
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# Data Retention (days)
DATA_RETENTION_DAYS=7

# Redis (for enrichment caching)
REDIS_URL=redis://redis:6379/0

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# GeoIP Database (download from MaxMind)
GEOIP_DB_PATH=/var/lib/geoip/GeoLite2-City.mmdb

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# OpenTelemetry
OTEL_SERVICE_NAME=log-management-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Frontend
VITE_API_URL=/api/v1
