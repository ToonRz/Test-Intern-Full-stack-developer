# Application
APP_NAME="Log Management System"
DEBUG=false
API_PREFIX=/api/v1

# ── Secrets (override before `make up`) ───────────────────────────────────
#
# Generate strong random values with:
#   openssl rand -hex 32
#
# I-C7: the .env.example used to ship live `postgres:postgres` credentials,
# inviting copy-paste. The placeholders below must be replaced before the
# stack can boot (docker-compose's `${VAR:?message}` syntax aborts early).

# Database credentials (consumed by docker-compose to provision Postgres
# and the backend's DATABASE_URL).
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=logs

# Database URL — keep in sync with POSTGRES_USER/POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+asyncpg://CHANGE_ME:CHANGE_ME@postgres:5432/logs

# Redis password (consumed by docker-compose's `redis-server --requirepass`
# and the backend's REDIS_URL).
REDIS_PASSWORD=CHANGE_ME_REDIS

# Redis URL — uses the password from REDIS_PASSWORD above.
REDIS_URL=redis://:CHANGE_ME_REDIS@redis:6379/0

# JWT Authentication — MUST be a 32+ char random value in production.
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Syslog Listener
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=514

# Data Retention (days)
DATA_RETENTION_DAYS=7

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# GeoIP Database (download from MaxMind)
GEOIP_DB_PATH=/var/lib/geoip/GeoLite2-City.mmdb

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# OpenTelemetry
OTEL_SERVICE_NAME=log-management-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Frontend
VITE_API_URL=/api/v1
